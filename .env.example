# NEXUS Configuration
# Copy this file to .env and customize for your environment

# --- Mode Selection ---
# local: Ollama only (no cloud) | cloud: Cloud LLMs only | hybrid: Local retrieval + cloud generation
NEXUS_MODE=hybrid

# --- LLM Provider ---
# ollama | anthropic | openai | vertex | openai_compatible
NEXUS_LLM_PROVIDER=ollama

# --- Embedding Provider ---
# ollama | openai | vertex   (forced local in local/hybrid modes by the policy gate)
NEXUS_EMBED_PROVIDER=ollama

# --- Fallback routing (optional) ---
# Comma-separated LLM providers tried in order if the preferred one is
# unavailable. Ollama is always the final local-emergency fallback.
NEXUS_LLM_FALLBACK=

# --- Ollama Configuration ---
# Generation and embeddings use SEPARATE models. Small local options:
#   gen:   qwen2.5:0.5b (~400MB) | gemma2:2b | tinyllama | llama3
#   embed: nomic-embed-text (~274MB, default) | all-minilm (~45MB, tiniest)
OLLAMA_MODEL=llama3
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434

# --- Retrieval backend ---
# chroma: dense vector store (default, zero extra deps)
# qmd:    homegrown hybrid (BM25 + vector + rerank) via the qmd CLI; falls back
#         to chroma if the qmd binary is absent.
NEXUS_RETRIEVER=chroma
QMD_BIN=qmd
# Refuse ("insufficient evidence") when the top retrieval score is below this
# floor. 0.0 disables the floor.
MIN_RETRIEVAL_SCORE=0.0

# --- Anthropic Configuration (optional, for cloud/hybrid mode) ---
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- OpenAI Configuration (optional, for cloud/hybrid mode) ---
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview
# Use the OpenAI Responses API path instead of Chat Completions
OPENAI_USE_RESPONSES_API=false

# --- OpenAI-compatible / OpenRouter (optional) ---
# One adapter for any OpenAI-compatible endpoint (OpenRouter, Together, vLLM,
# LM Studio, llama.cpp). Set NEXUS_LLM_PROVIDER=openai_compatible to use it.
# Set OPENAI_COMPATIBLE_IS_LOCAL=true ONLY for a self-hosted endpoint on this
# host so the policy gate treats it as local (default false = external).
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=
OPENAI_COMPATIBLE_IS_LOCAL=false

# --- Google Vertex AI Configuration (optional, for cloud/hybrid mode) ---
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=us-central1
VERTEX_MODEL=gemini-1.5-pro

# --- CLI safety ---
# Comma-separated roots the `nexus index` CLI is allowed to read from. Defaults
# to the current working directory. Confines an agent-driven CLI so it cannot be
# steered into indexing sensitive files (e.g. /etc/shadow) and exfiltrating them.
NEXUS_ALLOWED_INDEX_ROOTS=

# --- Document Processing ---
DOCUMENTS_DIR=documents
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# --- Vector Store ---
CHROMA_DB_PATH=./chroma_db_optimized
CACHE_DIR=./rag_cache

# --- Performance Tuning ---
EMBEDDING_BATCH_SIZE=50
MAX_WORKERS=4
CACHE_TTL=3600
MAX_CACHE_SIZE=100

# --- API Configuration ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# --- API security ---
# If set, /query /index /workspaces /runs /audit require this key
# (Authorization: Bearer <key>  OR  X-API-Key: <key>). Unset = open (local dev).
NEXUS_API_KEY=
# CORS allowlist (comma-separated). Default is localhost UI/API origins, NOT "*".
# Set to "*" only if you explicitly want a wildcard (unsafe with an open API).
NEXUS_CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501,http://localhost:8000

# --- Privacy/Security Settings ---
# When true, only send retrieved snippets to cloud (not full documents)
HYBRID_SAFE_MODE=true
# Maximum characters to send to cloud LLM
MAX_SNIPPET_LENGTH=4000
