# NEXUS Configuration
# Copy this file to .env and customize for your environment

# --- Mode Selection ---
# local: Ollama only (no cloud) | cloud: Cloud LLMs only | hybrid: Local retrieval + cloud generation
NEXUS_MODE=hybrid

# --- LLM Provider ---
# ollama | anthropic | openai | vertex | openai_compatible
NEXUS_LLM_PROVIDER=ollama

# --- Embedding Provider ---
# ollama | openai | vertex   (forced local in local/hybrid modes by the policy gate)
NEXUS_EMBED_PROVIDER=ollama

# --- Fallback routing (optional) ---
# Comma-separated LLM providers tried in order if the preferred one is
# unavailable. Ollama is always the final local-emergency fallback.
NEXUS_LLM_FALLBACK=

# --- Ollama Configuration ---
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# --- Anthropic Configuration (optional, for cloud/hybrid mode) ---
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- OpenAI Configuration (optional, for cloud/hybrid mode) ---
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview
# Use the OpenAI Responses API path instead of Chat Completions
OPENAI_USE_RESPONSES_API=false

# --- OpenAI-compatible / OpenRouter (optional) ---
# One adapter for any OpenAI-compatible endpoint (OpenRouter, Together, vLLM,
# LM Studio, llama.cpp). Set NEXUS_LLM_PROVIDER=openai_compatible to use it.
# Set OPENAI_COMPATIBLE_IS_LOCAL=true ONLY for a self-hosted endpoint on this
# host so the policy gate treats it as local (default false = external).
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=
OPENAI_COMPATIBLE_IS_LOCAL=false

# --- Google Vertex AI Configuration (optional, for cloud/hybrid mode) ---
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=us-central1
VERTEX_MODEL=gemini-1.5-pro

# --- Document Processing ---
DOCUMENTS_DIR=documents
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# --- Vector Store ---
CHROMA_DB_PATH=./chroma_db_optimized
CACHE_DIR=./rag_cache

# --- Performance Tuning ---
EMBEDDING_BATCH_SIZE=50
MAX_WORKERS=4
CACHE_TTL=3600
MAX_CACHE_SIZE=100

# --- API Configuration (Phase 3) ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# --- Privacy/Security Settings ---
# When true, only send retrieved snippets to cloud (not full documents)
HYBRID_SAFE_MODE=true
# Maximum characters to send to cloud LLM
MAX_SNIPPET_LENGTH=4000
